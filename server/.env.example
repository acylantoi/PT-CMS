# Server Configuration
PORT=5000
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────────
# Option A: Supabase (recommended for production/Vercel)
# Get this from: Supabase Dashboard → Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Option B: Local PostgreSQL (for local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pt_cms
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=pt-cms-secret-change-in-production-2026
JWT_EXPIRES_IN=8h

# Session
SESSION_TIMEOUT_MINUTES=30

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# CORS
CORS_ORIGIN=http://localhost:3000
